#---------------------------------------
*.aux
*.bbl
*.bcf
*.blg
*.out
*.log
*.toc
*.lot
*.lof
*.fls
*.fdb_latexmk
*.synctex.gz
*.tex
*.cls
*.sty
#---------------------------------------
# Documents
#---------------------------------------
*.pdf
*.doc
*.docx
*.ppt
*.pptx
*.xls
*.xlsx
*.rtf
#---------------------------------------
# Images
#---------------------------------------
*.png
*.jpg
*.jpeg
*.svg
*.fig

