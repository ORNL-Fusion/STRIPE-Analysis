###############################################################################
# FRESH CLEAN GITIGNORE — STRIPE-Analysis
###############################################################################
# --- DIII-D ---
DIII-D/**
!DIII-D/simulations/
!DIII-D/simulations/**/*

# --- iter ---
iter/**
!iter/simulations/
!iter/simulations/**/*

# --- west ---
west/**
!west/simulations/
!west/simulations/**/*
#---------------------------------------
# Simulation / Data (large files)
#---------------------------------------
*.mat
*.nc
*.csv
*.txt
*.pkl
*.npz
*.npy

# Ignore tar + zip archives
*.tar
*.tar.gz
*.tgz
*.zip
# ===== Large simulation / CAD / dataset files =====
# HDF5, matrices, etc.
*.h5
radiation_matrix

# nohup logs
nohup.out

# CAD (SolidWorks)
*.SLDPRT
*.SLDASM

# COMSOL / geometry / scenario zips etc.
*.stp
*.zip
*.msh

# ORNL email COMSOL–GITR datasets (explicit paths just in case)
iter/simulations/Expt_data/ORNL_Email_20230518_1/
west/simulations/soledge_postprocess/sim_O_4mw_main/run_dir/
DIII-D/simulations/HeliconCAD/
iter/simulations/ieads/old/Ne_2prcnt/
iter/simulations/ieads/old/Ne_5prcnt/
