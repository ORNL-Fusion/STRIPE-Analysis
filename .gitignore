# CAD / Geometry files
#---------------------------------------
*.stp
*.stl
*.SLDPRT
*.SLDASM

# CAD directories
DIII-D/simulations/DIII-D helicon CAD/

# ITER geometry & COMSOL-GITR inputs
iter/simulations/Expt_data/ITER_geom.msh
iter/simulations/Expt_data/ORNL_Email_20230518_1/v1p1_COMSOL-GITR_Inputs_PartI_Geometries/
