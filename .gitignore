###############################################################################
# STRIPE-Analysis .gitignore
# Whitelist approach: ignore everything, then explicitly allow code/scripts.
###############################################################################

# Ignore everything by default
*

# Un-ignore directories so git can recurse into subdirectories
!*/

# ----- Source code and scripts -----
!*.m
!*.py
!*.sh
!*.bash
!*.zsh
!*.cpp
!*.c
!*.h
!*.hpp
!*.f90
!*.F90
!*.f
!*.F

# ----- Simulation input / configuration -----
!*.in
!*.cmake
!CMakeLists.txt
!*.json
!*.yaml
!*.yml
!*.toml

# ----- Documentation -----
!*.md
!*.rst
!*.tex

# ----- Git infrastructure -----
!.gitignore
!.gitattributes
!.gitmodules

# ----- Embedded repos (kept as independent git repos, not submodules) -----
iter/simulations/geometry/EMC3-EIRENE/BOUNDARY/moose/
protoMPEX/simulations/gitr_PostProcessing_ProtoMPEX/
west/simulations/curt_divertor/soledge-curt/
west/simulations/gitrProcessing_WEST_CURT/soledge-main/
west/simulations/gitrProcessing_WestCmod/

###############################################################################
# End of .gitignore
###############################################################################
